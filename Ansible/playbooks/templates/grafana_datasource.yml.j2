# ==============================================================
# grafana_datasource.yml.j2  –  Grafana datasource provisioning
# Managed by Ansible – DO NOT edit manually on the server
# ==============================================================

apiVersion: 1

datasources:
  - name: Prometheus
    type: prometheus
    uid: spendwise-prometheus
    access: proxy
    url: "http://localhost:9090"
    isDefault: true
    editable: false
    jsonData:
      httpMethod: POST
      timeInterval: "15s"
      queryTimeout: "60s"
      # Link Prometheus exemplars to Jaeger traces
      exemplarTraceIdDestinations:
        - name: trace_id
          datasourceUid: spendwise-jaeger
    version: 1

  - name: Jaeger
    type: jaeger
    uid: spendwise-jaeger
    access: proxy
    url: "http://localhost:16686"
    isDefault: false
    editable: false
    version: 1
